# Ai Clone Studio — Environment Variables
# Copy this file to .env.local and fill in your values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Ai Clone Studio"

# OpenAI (for AI generation features)
OPENAI_API_KEY=your_openai_api_key_here

# ElevenLabs (for voice cloning)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-clone-studio

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/aiclonestudio

# Redis (for job queues)
REDIS_URL=redis://localhost:6379

# Authentication (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
